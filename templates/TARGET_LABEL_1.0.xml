<?xml version='1.0' encoding='UTF-8'?>
<?xml-model href="https://pds.nasa.gov/pds4/pds/v1/PDS4_PDS_1M00.sch"
schematypens="http://purl.oclc.org/dsdl/schematron"?>
<Product_Context xmlns="http://pds.nasa.gov/pds4/pds/v1"
                 xmlns:pds="http://pds.nasa.gov/pds4/pds/v1"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://pds.nasa.gov/pds4/pds/v1
                 https://pds.nasa.gov/pds4/pds/v1/PDS4_PDS_1M00.xsd">
  <Identification_Area>
    <logical_identifier>$target['lid']$</logical_identifier>
    <version_id>1.0</version_id>
    <title>$target['title']$</title>
    <information_model_version>1.22.0.0</information_model_version>
    <product_class>Product_Context</product_class>
  $IF(len(target['alt_titles']))
    <Alias_List>
    $FOR(alt=target['alt_titles'])
      <Alias>
        <alternate_title>$alt$</alternate_title>
      </Alias>
    $END_FOR
    </Alias_List>
  $END_IF
    <Modification_History>
      <Modification_Detail>
        <modification_date>$CURRENT_TIME(date_only=True)$</modification_date>
        <version_id>1.0</version_id>
        <description>Initial version from PDS RMS Node</description>
      </Modification_Detail>
    </Modification_History>
  </Identification_Area>
  <Target>
    <name>$target['title']$</name>
    <type>$target['type_name']$</type>
    $IF(len(target['description']))
      <description>
        $WRAP(8, 80, target['description'].strip())$
      </description>
    $ELSE_IF(len(target['description']) == 0)
      <description>none</description>
    $END_IF
  </Target>
</Product_Context>
